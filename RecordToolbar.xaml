<Window x:Class="SmartMacroAI.RecordToolbar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ui_Record_Title}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#45475A" BorderThickness="1"
            Padding="16,10,16,8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#11111B" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <!-- Blinking red dot -->
                <Ellipse x:Name="RecordDot" Width="12" Height="12" Margin="0,0,10,0"
                         VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="#F38BA8" />
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock Text="REC" FontSize="13" FontWeight="Bold"
                           Foreground="#F38BA8" VerticalAlignment="Center" Margin="0,0,14,0" />

                <!-- Timer -->
                <TextBlock x:Name="TxtTimer" Text="00:00" FontSize="15" FontWeight="SemiBold"
                           Foreground="#CDD6F4" VerticalAlignment="Center" FontFamily="Consolas"
                           Margin="0,0,14,0" />

                <!-- Separator -->
                <Border Width="1" Height="18" Background="#45475A" Margin="0,0,14,0"
                        VerticalAlignment="Center" />

                <!-- Action count -->
                <TextBlock x:Name="TxtActionCount" Text="{DynamicResource ui_Record_ActionCount}" FontSize="12"
                           Foreground="#A6ADC8" VerticalAlignment="Center" Margin="0,0,16,0" />

                <!-- Stop button -->
                <Button Click="BtnStop_Click" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#F38BA8" />
                            <Setter Property="Foreground" Value="#11111B" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Padding" Value="14,6" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#EBA0AC" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock>
                        <Run Text="&#x23F9;" />
                        <Run Text="{DynamicResource ui_Record_Stop}" />
                    </TextBlock>
                </Button>
            </StackPanel>

            <!-- Credit footer -->
            <TextBlock Text="{DynamicResource ui_Footer_Credit}"
                       FontSize="8" Foreground="#6C7086" HorizontalAlignment="Center"
                       Margin="0,6,0,0" />
        </StackPanel>
    </Border>
</Window>
