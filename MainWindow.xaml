                    <!-- ────── Macro Editor View ────── -->
                    <Grid x:Name="MacroEditorView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="12">
                            <WrapPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_MacroName}" />
                                    <TextBox x:Name="TxtMacroName" Style="{StaticResource DarkTextBoxStyle}" Width="180" Text="{DynamicResource ui_DefaultMacroName}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_TargetWindowPid}" />
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="🎯" Click="BtnIdentifyWindow_Click"
