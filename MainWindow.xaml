                                            Background="#45475A" Foreground="#CDD6F4"
                                            BorderThickness="0" Cursor="Hand" FontSize="12"
                                            Content="📋 Log" />
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ui_ActionsPanel}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <Border Background="{StaticResource BaseBrush}" CornerRadius="0" Padding="8,4" Margin="0,1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="Click"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlueBrush}" Margin="0,0,10,0" /><TextBlock Text="{DynamicResource ui_Action_Click}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="{StaticResource BaseBrush}" CornerRadius="0" Padding="8,4" Margin="0,1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="TypeText"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,10,0" /><TextBlock Text="{DynamicResource ui_Action_TypeText}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#1E2030" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#89B4FA" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="KeyPress"><TextBlock Text="⌨" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_KeyPress}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="{StaticResource BaseBrush}" CornerRadius="0" Padding="8,4" Margin="0,1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="Wait"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentYellowBrush}" Margin="0,0,10,0" /><TextBlock Text="{DynamicResource ui_Action_Wait}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#2A2418" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#FFA500" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="Repeat"><Ellipse Width="8" Height="8" Fill="#FFA500" Margin="0,0,10,0" /><TextBlock Text="{DynamicResource ui_Action_Repeat}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#2A1F30" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#CBA6F7" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="SetVariable"><TextBlock Text="&#x1F4E6;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_SetVariable}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#152030" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#89B4FA" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="IfVariable"><TextBlock Text="&#x2753;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_IfVariable}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#252528" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#6C7086" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="Log"><TextBlock Text="&#x1F4DD;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_Log}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#301818" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#FE640B" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="TryCatch"><TextBlock Text="&#x1F6E1;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_TryCatch}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="{StaticResource BaseBrush}" CornerRadius="0" Padding="8,4" Margin="0,1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="IfImageFound"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentPeachBrush}" Margin="0,0,10,0" /><TextBlock Text="{DynamicResource ui_Action_IfImage}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="{StaticResource BaseBrush}" CornerRadius="0" Padding="8,4" Margin="0,1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="IfTextFound"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentLavenderBrush}" Margin="0,0,10,0" /><TextBlock Text="{DynamicResource ui_Action_IfText}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#1E2A38" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#74C7EC" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="OcrRegion"><TextBlock Text="&#x1F4D0;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_OcrRegion}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#2A2028" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#F5C2E7" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="ClearVar"><TextBlock Text="&#x1F5D1;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_ClearVar}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#1A2830" CornerRadius="0" Padding="8,4" Margin="0,1" BorderBrush="#A6E3A1" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="LogVar"><TextBlock Text="&#x1F4CB;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_LogVar}" Foreground="#CDD6F4" FontSize="12" /></StackPanel></Border>
                                            <Border Background="#1A3D3A" CornerRadius="0" Padding="8,4" Margin="0,4,0,1" BorderBrush="#94E2D5" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="WebAction"><TextBlock Text="&#x1F310;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="{DynamicResource ui_Action_WebAction}" Foreground="#CDD6F4" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel></Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ui_MacroWorkflow}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                    <Border CornerRadius="0" Background="{StaticResource BaseBrush}" BorderBrush="{StaticResource Surface1Brush}" BorderThickness="1" AllowDrop="True" DragOver="Canvas_DragOver" Drop="Canvas_Drop">
                                        <Grid>
                                            <TextBlock x:Name="CanvasPlaceholder" Text="{DynamicResource ui_CanvasPlaceholder}" FontSize="14" Foreground="{StaticResource OverlayBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl x:Name="MacroCanvas" Margin="8"
                                                              AllowDrop="True"
                                                              PreviewMouseLeftButtonDown="Workflow_PreviewMouseLeftButtonDown"
                                                              MouseMove="Workflow_MouseMove"
                                                              Drop="Workflow_Drop">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ────── Image Recognition View ────── -->
                    <Grid x:Name="ImageRecognitionView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource ui_Vision_Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <WrapPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_WindowTitle}" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="&#x21BB;" Click="BtnRefreshVisionWindows_Click" ToolTip="{DynamicResource ui_Tooltip_Refresh}" FontSize="14" Cursor="Hand" Margin="4,0,0,0" Background="{StaticResource Surface0Brush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8,6" />
                                            <ComboBox x:Name="CmbVisionWindowTitle" Width="220" IsEditable="True"
                                                     Style="{StaticResource DarkComboBoxStyle}"
                                                     FontSize="12"
                                                     DropDownOpened="CmbVisionWindowTitle_DropDownOpened" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8" MinWidth="280">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_TemplatePath}" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Browse}" Click="BtnBrowseTemplate_Click" Padding="12,8" Margin="4,0,0,0" />
                                            <Button DockPanel.Dock="Right" Style="{StaticResource DangerButtonStyle}" Content="{DynamicResource ui_Snip}" Click="BtnSnipArea_Click" Padding="12,8" Margin="4,0,0,0" />
                                            <TextBox x:Name="TxtTemplatePath" Style="{StaticResource DarkTextBoxStyle}" Width="220" />
                                        </DockPanel>
                                        <GroupBox Header="{DynamicResource ui_Vision_RoiHeader}" Margin="0,8,0,0" Padding="8,10,8,8" Foreground="{StaticResource TextBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="RoiX" Grid.Column="0" Margin="2" Style="{StaticResource DarkTextBoxStyle}" ToolTip="{DynamicResource ui_Vision_RoiTipX}" />
                                                <TextBox x:Name="RoiY" Grid.Column="1" Margin="2" Style="{StaticResource DarkTextBoxStyle}" ToolTip="{DynamicResource ui_Vision_RoiTipY}" />
                                                <TextBox x:Name="RoiWidth" Grid.Column="2" Margin="2" Style="{StaticResource DarkTextBoxStyle}" ToolTip="{DynamicResource ui_Vision_RoiTipW}" />
                                                <TextBox x:Name="RoiHeight" Grid.Column="3" Margin="2" Style="{StaticResource DarkTextBoxStyle}" ToolTip="{DynamicResource ui_Vision_RoiTipH}" />
                                                <Button x:Name="BtnClearRoi" Grid.Column="4" Margin="4,2" Padding="10,6" Style="{StaticResource PrimaryButtonStyle}"
                                                        Content="{DynamicResource ui_Vision_RoiClear}" Click="BtnClearRoi_Click" ToolTip="{DynamicResource ui_Vision_RoiClearTip}" />
                                                <Button x:Name="BtnPickRoi" Grid.Column="5" Margin="4,2" Padding="10,6" Style="{StaticResource SidebarButtonStyle}"
                                                        Content="📐" Click="BtnPickRoi_Click" ToolTip="{DynamicResource ui_Vision_RoiPickTip}" FontSize="14" />
                                            </Grid>
                                        </GroupBox>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_Threshold}" />
                                        <TextBox x:Name="TxtThreshold" Style="{StaticResource DarkTextBoxStyle}" Width="60" Text="0.8" />
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_TestCaptureMatch}" Click="BtnTestVision_Click" Padding="16,8" />
                                        <Button x:Name="BtnVisionStealthClick" Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Vision_ClickFound}" Click="BtnVisionStealthClick_Click" Padding="16,8" Margin="0,8,0,0" IsEnabled="False" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ui_Result}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <Border CornerRadius="0" Background="{StaticResource BaseBrush}" Padding="16">
                                    <TextBlock x:Name="TxtVisionResult" Text="{DynamicResource ui_Vision_ResultPlaceholder}" FontSize="13" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- ────── OCR Engine View ────── -->
                    <Grid x:Name="OcrEngineView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource ui_Ocr_Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <WrapPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_WindowTitle}" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="&#x21BB;" Click="BtnRefreshOcrWindows_Click" ToolTip="{DynamicResource ui_Tooltip_Refresh}" FontSize="14" Cursor="Hand" Margin="4,0,0,0" Background="{StaticResource Surface0Brush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8,6" />
                                            <ComboBox x:Name="CmbOcrWindowTitle" Width="280" IsEditable="True"
                                                     Style="{StaticResource DarkComboBoxStyle}"
                                                     FontSize="12"
                                                     DropDownOpened="CmbOcrWindowTitle_DropDownOpened" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Ocr_WinRtLanguage}" />
                                        <ComboBox x:Name="CmbWinRtOcrLanguage" Width="200" Style="{StaticResource DarkComboBoxStyle}" FontSize="12"
                                                  SelectionChanged="CmbWinRtOcrLanguage_SelectionChanged" />
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Ocr_WinRtLanguage}" />
                                        <ComboBox x:Name="CmbTesseractLanguage" Width="140" Style="{StaticResource DarkComboBoxStyle}" FontSize="12" Margin="0,4,0,6">
                                            <ComboBoxItem Content="{DynamicResource ui_OcrLang_En}" Tag="eng" IsSelected="True" />
                                            <ComboBoxItem Content="{DynamicResource ui_OcrLang_Vi}" Tag="vie" />
                                            <ComboBoxItem Content="{DynamicResource ui_OcrLang_Both}" Tag="eng+vie" />
                                        </ComboBox>
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_ExtractText}" Click="BtnTestOcr_Click" Padding="16,8" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource ui_ExtractedText}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <Border CornerRadius="0" Background="{StaticResource BaseBrush}" Padding="16">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="TxtOcrResult" Text="{DynamicResource ui_Ocr_ResultPlaceholder}" FontSize="13" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- ────── Stealth Manager View ────── -->
                    <Grid x:Name="StealthManagerView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="{DynamicResource ui_Stealth_ShowAll}" Click="BtnShowAllStealth_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Refresh}" Click="BtnRefreshStealth_Click" Padding="12,6" FontSize="11" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ui_Stealth_Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{DynamicResource ui_Stealth_Subtitle}" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                            <DataGrid x:Name="StealthGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      CanUserReorderColumns="False" CanUserSortColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single" SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource Surface1Brush}"
                                      Background="{StaticResource BaseBrush}"
                                      RowBackground="#1E1E2E"
                                      AlternatingRowBackground="#21213A"
                                      BorderThickness="0"
                                      ColumnHeaderHeight="36"
                                      RowHeight="42"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource MantelBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="FontSize" Value="11" />
                                        <Setter Property="Padding" Value="10,8" />
                                        <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
                                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2A2A3D" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="IsHitTestVisible" Value="True" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <ContentPresenter VerticalAlignment="Center" Margin="8,4" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="{DynamicResource ui_Col_Window}" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding WindowTitle}" FontSize="12" Foreground="#CDD6F4"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="{DynamicResource ui_Col_StealthStatus}" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusKey, Converter={StaticResource StealthStatusLocConverter}}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#A6E3A1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                    <Setter Property="Foreground" Value="#F38BA8" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="{DynamicResource ui_Col_StealthAction}" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding ToggleKey, Converter={StaticResource StealthToggleLocConverter}}" Click="StealthToggle_Click"
                                                        FontSize="11" Padding="10,4" Cursor="Hand"
                                                        BorderThickness="0" FontWeight="SemiBold">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#F38BA8" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                    <Setter Property="Background" Value="#A6E3A1" />
                                                                    <Setter Property="Foreground" Value="#1E1E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- ────── Profile Manager View ────── -->
                    <Grid x:Name="ProfileManagerView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Profile_Add}" Click="BtnAddProfile_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="{DynamicResource ui_Profile_Delete}" Click="BtnDeleteProfile_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" />
                                    <Button Style="{StaticResource SidebarButtonStyle}" Content="{DynamicResource ui_Profile_Test}" Click="BtnTestProfile_Click" Padding="12,6" FontSize="11" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ui_Profile_Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{DynamicResource ui_Profile_Subtitle}" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,2,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- DataGrid -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                            <DataGrid x:Name="ProfileGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      CanUserReorderColumns="False" CanUserSortColumns="True"
                                      SelectionMode="Single" SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource Surface1Brush}"
                                      Background="{StaticResource BaseBrush}"
                                      RowBackground="#1E1E2E"
                                      AlternatingRowBackground="#21213A"
                                      BorderThickness="0"
                                      ColumnHeaderHeight="36"
                                      RowHeight="42"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#181825" />
                                        <Setter Property="Foreground" Value="{StaticResource OverlayBrush}" />
                                        <Setter Property="FontSize" Value="11" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Padding" Value="10,0" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="{StaticResource Surface0Brush}" />
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="#1E1E2E" />
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="FontSize" Value="12" />
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="10,0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#45475A" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ui_Profile_Col_ProfileId}" Binding="{Binding ProfileId}" Width="180" IsReadOnly="True" />
                                    <DataGridTextColumn Header="{DynamicResource ui_Profile_Col_Name}" Binding="{Binding Name}" Width="200" />
                                    <DataGridTextColumn Header="{DynamicResource ui_Profile_Col_Proxy}" Binding="{Binding ProxySummary}" Width="180" IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="{DynamicResource ui_Profile_Col_Status}" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Status}" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="OK">
                                                                    <Setter Property="Foreground" Value="#A6E3A1" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                    <Setter Property="Foreground" Value="#F38BA8" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- ────── Settings View ────── -->
                    <Grid x:Name="SettingsView" Visibility="Collapsed">
                        <TabControl Background="Transparent" BorderThickness="0" Padding="0,4,0,0">
                            <TabItem Header="{DynamicResource ui_Settings_Tab_General}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="600">
                                <!-- Language -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ui_Settings_Language}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                        <ComboBox x:Name="CmbUiLanguage" Width="220" Margin="0,8,0,0" HorizontalAlignment="Left"
                                                  Style="{StaticResource DarkComboBoxStyle}" FontSize="12"
                                                  SelectionChanged="CmbUiLanguage_SelectionChanged" />
                                    </StackPanel>
                                </Border>

                                <!-- Image recognition — template scale range -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ui_Settings_VisionScaleTitle}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                        <TextBlock Text="{DynamicResource ui_Settings_VisionScaleNote}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Settings_VisionScaleMin}" />
                                        <DockPanel Margin="0,6,0,8">
                                            <TextBlock x:Name="TxtVisionMinScaleValue" DockPanel.Dock="Right" MinWidth="48" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBrush}" />
                                            <Slider x:Name="SldVisionMinScale" Minimum="0.50" Maximum="1.50" TickFrequency="0.01" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SldVisionScale_ValueChanged" />
                                        </DockPanel>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Settings_VisionScaleMax}" />
                                        <DockPanel Margin="0,6,0,12">
                                            <TextBlock x:Name="TxtVisionMaxScaleValue" DockPanel.Dock="Right" MinWidth="48" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBrush}" />
                                            <Slider x:Name="SldVisionMaxScale" Minimum="0.80" Maximum="2.00" TickFrequency="0.01" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SldVisionScale_ValueChanged" />
                                        </DockPanel>
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_SaveVisionScales}" Click="BtnSaveVisionScales_Click" Padding="20,10" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>

                                <!-- Global Hotkeys -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ui_Settings_GlobalHotkeys}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                        <TextBlock Text="{DynamicResource ui_Settings_HotkeysBlurb}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Settings_ToggleApp}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                                            <ComboBox x:Name="CmbToggleAppMod" Width="130"
                                                      Style="{StaticResource DarkComboBoxStyle}" FontSize="12" />
                                            <TextBlock Text="{DynamicResource ui_Settings_Plus}" FontSize="14" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" />
                                            <ComboBox x:Name="CmbToggleAppKey" Width="90"
                                                      Style="{StaticResource DarkComboBoxStyle}" FontSize="12" />
                                        </StackPanel>

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Settings_ToggleTarget}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                                            <ComboBox x:Name="CmbToggleTargetMod" Width="130"
                                                      Style="{StaticResource DarkComboBoxStyle}" FontSize="12" />
                                            <TextBlock Text="{DynamicResource ui_Settings_Plus}" FontSize="14" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" />
                                            <ComboBox x:Name="CmbToggleTargetKey" Width="90"
                                                      Style="{StaticResource DarkComboBoxStyle}" FontSize="12" />
                                        </StackPanel>

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Settings_ToggleMacro}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                                            <ComboBox x:Name="CmbToggleMacroMod" Width="130"
                                                      Style="{StaticResource DarkComboBoxStyle}" FontSize="12" />
                                            <TextBlock Text="{DynamicResource ui_Settings_Plus}" FontSize="14" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" />
                                            <ComboBox x:Name="CmbToggleMacroKey" Width="90"
                                                      Style="{StaticResource DarkComboBoxStyle}" FontSize="12" />
                                        </StackPanel>

                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_SaveHotkeys}" Click="BtnSaveHotkeys_Click" Padding="20,10" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>

                                <!-- Tray Info -->
                                <Border Style="{StaticResource CardStyle}" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ui_Settings_SystemTray}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SubtextBrush}" Text="{DynamicResource ui_Settings_TrayBlurb}" />
                                    </StackPanel>
                                </Border>

                                <!-- Tutorial -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ui_Settings_TutorialTitle}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SubtextBrush}" Text="{DynamicResource ui_Settings_TutorialBlurb}" Margin="0,0,0,12" />
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Settings_RestartTutorial}" Click="BtnRestartTutorial_Click" Padding="20,10" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                            </TabItem>
                            <TabItem Header="{DynamicResource ui_Settings_Tab_Mouse}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="600" Margin="0,8,0,0">
                                        <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource ui_MouseSettings_Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                                <TextBlock Text="{DynamicResource ui_MouseSettings_Blurb}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_MouseSettings_Profile}" />
                                                <ComboBox x:Name="CmbMouseProfile" Width="220" Margin="0,6,0,16" HorizontalAlignment="Left"
                                                          Style="{StaticResource DarkComboBoxStyle}" FontSize="12"
                                                          SelectionChanged="CmbMouseProfile_SelectionChanged" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_MouseSettings_Jitter}" />
                                                <DockPanel Margin="0,6,0,8">
                                                    <TextBlock x:Name="TxtMouseJitterValue" DockPanel.Dock="Right" MinWidth="36" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBrush}" />
                                                    <Slider x:Name="SldMouseJitter" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                                                            VerticalAlignment="Center" ValueChanged="SldMouseJitter_ValueChanged" />
                                                </DockPanel>
                                                <CheckBox x:Name="ChkMouseOvershoot" Content="{DynamicResource ui_MouseSettings_Overshoot}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                                                          Checked="ChkMousePreview_Changed" Unchecked="ChkMousePreview_Changed" />
                                                <CheckBox x:Name="ChkMouseMicroPause" Content="{DynamicResource ui_MouseSettings_MicroPause}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"
                                                          Checked="ChkMousePreview_Changed" Unchecked="ChkMousePreview_Changed" />
                                                <CheckBox x:Name="ChkMouseRawBypass" Content="{DynamicResource ui_MouseSettings_RawBypass}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkMouseHwSim" Content="{DynamicResource ui_MouseSettings_HwSim}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16" />
                                                <Button x:Name="BtnSaveMouseSettings" Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_MouseSettings_Save}"
                                                        Click="BtnSaveMouseSettings_Click" Padding="20,10" HorizontalAlignment="Left" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource ui_MouseSettings_PreviewTitle}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <Border Background="#11111B" BorderBrush="#45475A" BorderThickness="1" Height="200" ClipToBounds="True">
                                                    <Canvas x:Name="MousePreviewCanvas" Width="360" Height="200" SnapsToDevicePixels="True">
                                                        <Polyline x:Name="MousePreviewPolyline" Stroke="#89B4FA" StrokeThickness="2" />
                                                    </Canvas>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="{DynamicResource ui_Settings_Tab_AntiDetection}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="620" Margin="0,8,0,0">
                                        <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource ui_Anti_Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                                <TextBlock Text="{DynamicResource ui_Anti_Blurb}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />
                                                <CheckBox x:Name="ChkAntiEnabled" Content="{DynamicResource ui_Anti_Enable}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkAntiFatigue" Content="{DynamicResource ui_Anti_Fatigue}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkAntiMicroPause" Content="{DynamicResource ui_Anti_MicroPause}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkAntiSessionBreak" Content="{DynamicResource ui_Anti_SessionBreak}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkAntiCpuTweak" Content="{DynamicResource ui_Anti_CpuTweak}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkAntiHookScan" Content="{DynamicResource ui_Anti_HookScan}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkAntiScanTyping" Content="{DynamicResource ui_Anti_ScanTyping}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <CheckBox x:Name="ChkAntiCapture" Content="{DynamicResource ui_Anti_Capture}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"
                                                          Checked="ChkAntiCapture_Changed" Unchecked="ChkAntiCapture_Changed" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Anti_Misclick}" />
                                                <DockPanel Margin="0,6,0,12">
                                                    <TextBlock x:Name="TxtAntiMisclickValue" DockPanel.Dock="Right" MinWidth="32" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBrush}" />
                                                    <Slider x:Name="SldAntiMisclick" Minimum="0" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True"
                                                            ValueChanged="SldAntiMisclick_ValueChanged" />
                                                </DockPanel>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Anti_SessionMin}" />
                                                <TextBox x:Name="TxtAntiSessionMin" Style="{StaticResource DarkTextBoxStyle}" Width="120" HorizontalAlignment="Left" Margin="0,6,0,12" />
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Anti_BreakRange}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,12">
                                                    <TextBox x:Name="TxtAntiBreakMin" Style="{StaticResource DarkTextBoxStyle}" Width="56" Margin="0,0,8,0" />
                                                    <TextBlock Text="–" VerticalAlignment="Center" Foreground="{StaticResource SubtextBrush}" Margin="0,0,8,0" />
                                                    <TextBox x:Name="TxtAntiBreakMax" Style="{StaticResource DarkTextBoxStyle}" Width="56" />
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Anti_DecoyTitles}" />
                                                <TextBox x:Name="TxtAntiDecoyTitles" Style="{StaticResource DarkTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" Height="100" VerticalScrollBarVisibility="Auto" Margin="0,6,0,16" />
                                                <Button x:Name="BtnSaveAntiDetection" Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Anti_Save}"
                                                        Click="BtnSaveAntiDetection_Click" Padding="20,10" HorizontalAlignment="Left" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem x:Name="TabDataCsv" Header="{DynamicResource ui_Settings_Tab_DataCSV}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="700" Margin="0,8,0,24">
                                        <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource ui_Settings_DataCSV_Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                                <TextBlock Text="{DynamicResource ui_Settings_DataCSV_Subtitle}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

                                                <!-- Load CSV button + file info -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button x:Name="BtnLoadCsvData" Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Settings_DataCSV_LoadButton}" Click="BtnLoadCsvData_Click" Padding="16,10" FontSize="13" />
                                                    <Button x:Name="BtnClearCsvData" Style="{StaticResource SidebarButtonStyle}" Content="{DynamicResource ui_Settings_DataCSV_ClearButton}" Click="BtnClearCsvData_Click" Padding="12,10" FontSize="12" Margin="8,0,0,0" />
                                                </StackPanel>

                                                <!-- File name + row count label -->
                                                <TextBlock x:Name="TxtCsvFileInfo" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4" />

                                                <!-- Preview table -->
                                                <Border x:Name="CsvPreviewBorder" Visibility="Collapsed" BorderBrush="{StaticResource Surface0Brush}" BorderThickness="1" Margin="0,8,0,0">
                                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                                        <TextBlock x:Name="TxtCsvPreview" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource SubtextBrush}" Padding="8" />
                                                    </ScrollViewer>
                                                </Border>

                                                <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,16" />

                                                <!-- Skip on error checkbox -->
                                                <CheckBox x:Name="ChkCsvSkipOnError" IsChecked="True" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4">
                                                    <TextBlock Text="{DynamicResource ui_Settings_DataCSV_SkipOnError}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextBrush}" />
                                                </CheckBox>
                                                <TextBlock Text="{DynamicResource ui_Settings_DataCSV_SkipDesc}" FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="20,0,0,0" TextWrapping="Wrap" />

                                                <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,16" />

                                                <!-- How-to note -->
                                                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Padding="12" Margin="0,4,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="{DynamicResource ui_Settings_DataCSV_HowToUse}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,6" />
                                                        <TextBlock Text="{DynamicResource ui_Settings_DataCSV_Step1}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" Margin="0,0,0,3" />
                                                        <TextBlock Text="{DynamicResource ui_Settings_DataCSV_Step2}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" Margin="0,0,0,3" />
                                                        <TextBlock Text="{DynamicResource ui_Settings_DataCSV_Step3}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" Margin="0,0,0,3" />
                                                        <TextBlock Text="{DynamicResource ui_Settings_DataCSV_Step4}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" Margin="0,0,0,3" />
                                                        <TextBlock Text="{DynamicResource ui_Settings_DataCSV_Step5}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem x:Name="TabTelegram" Header="{DynamicResource ui_Settings_Tab_Telegram}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="620" Margin="0,8,0,24">
                                        <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource ui_Settings_Telegram_Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                                <TextBlock Text="{DynamicResource ui_Settings_Telegram_Subtitle}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16" TextWrapping="Wrap" />

                                                <TextBlock Text="{DynamicResource ui_Settings_Telegram_TokenLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" Margin="0,0,0,4" />
                                                <PasswordBox x:Name="TxtTelegramBotToken" Width="400" HorizontalAlignment="Left" Margin="0,0,0,16"
                                                    Background="#1E1E2E" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"
                                                    Padding="8,6" FontSize="12" />

                                                <TextBlock Text="{DynamicResource ui_Settings_Telegram_ChatIdLabel}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" Margin="0,0,0,4" />
                                                <TextBox x:Name="TxtTelegramChatId" Width="400" HorizontalAlignment="Left" Margin="0,0,0,12"
                                                    Background="#1E1E2E" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"
                                                    Padding="8,6" FontSize="12" />

                                                <CheckBox x:Name="ChkScreenshotOnError"
                                                    Content="{DynamicResource ui_Settings_Screenshot}"
                                                    IsChecked="{Binding Source={x:Static settings:AppSettings.Instance}, Path=ScreenshotOnError}"
                                                    Foreground="#CDD6F4" Margin="0,0,0,4"/>
                                                <TextBlock Text="{DynamicResource ui_Settings_ScreenshotDesc}"
                                                    Foreground="#6C7086" FontSize="11" Margin="20,0,0,0"/>

                                                <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,12,0,16" />

                                                <TextBlock Text="{DynamicResource ui_Settings_Telegram_HowToTitle}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />

                                                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <TextBlock Text="{DynamicResource ui_Settings_Telegram_Step1}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                                        <TextBlock Text="{DynamicResource ui_Settings_Telegram_Step2}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                                        <TextBlock Text="{DynamicResource ui_Settings_Telegram_Step3}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,4,0,16" />

                                                <TextBlock Text="{DynamicResource ui_Settings_Telegram_TestTitle}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                                <Button x:Name="BtnTestTelegramGlobal" Style="{StaticResource SidebarButtonStyle}"
                                                    Content="{DynamicResource ui_Settings_Telegram_TestButton}"
                                                    Click="BtnTestTelegramGlobal_Click"
                                                    Padding="16,10" FontSize="13" HorizontalAlignment="Left" Margin="0,0,0,8" />
                                                <TextBlock Text="{DynamicResource ui_Settings_Telegram_TestDesc}" FontSize="11" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem x:Name="TabDriver" Header="{DynamicResource ui_Settings_Tab_Driver}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel MaxWidth="620" Margin="0,8,0,24">
                                        <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="🎮" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{DynamicResource ui_Drv_ModeLabel}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                        <TextBlock Text="{DynamicResource ui_Drv_Subtitle}" FontSize="12" Foreground="{StaticResource SubtextBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,12" LineHeight="20">
                                                    <Run Text="{DynamicResource ui_Drv_Desc1}"/><Bold Foreground="{StaticResource TextBrush}"><Run Text="{DynamicResource ui_Drv_DescBold}"/></Bold><Run Text="{DynamicResource ui_Drv_Desc2}"/>
                                                </TextBlock>

                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="✅ " FontSize="12" Foreground="{StaticResource SubtextBrush}">
                                                        <Run Text="{DynamicResource ui_Drv_Feat1}"/><Bold Foreground="{StaticResource TextBrush}"><Run Text="{DynamicResource ui_Drv_Feat1Bold}"/></Bold>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource SubtextBrush}">
                                                        <Run Text="✅ "/><Run Text="{DynamicResource ui_Drv_Feat2}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="12" Foreground="{StaticResource SubtextBrush}">
                                                        <Run Text="✅ "/><Run Text="{DynamicResource ui_Drv_Feat3}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Status -->
                                                <Border Background="#11111B" BorderBrush="#45475A" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="TxtDriverStatus" Text="{DynamicResource ui_Drv_StatusChecking}" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Buttons -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Button x:Name="BtnDriverInstall" Style="{StaticResource PrimaryButtonStyle}"
                                                            Content="{DynamicResource ui_Drv_InstallBtn}"
                                                            Click="BtnDriverInstall_Click"
                                                            Padding="16,10" FontSize="13" Margin="0,0,8,0"/>
                                                    <Button x:Name="BtnDriverUninstall" Style="{StaticResource SidebarButtonStyle}"
                                                            Content="{DynamicResource ui_Drv_UninstallBtn}"
                                                            Click="BtnDriverUninstall_Click"
                                                            Padding="16,10" FontSize="12" Margin="0,0,8,0"/>
                                                    <Button x:Name="BtnDriverManualGuide" Style="{StaticResource SidebarButtonStyle}"
                                                            Content="{DynamicResource ui_Drv_ManualGuideBtn}"
                                                            Click="BtnDriverManualGuide_Click"
                                                            Padding="16,10" FontSize="12"/>
                                                </StackPanel>

                                                <!-- Progress -->
                                                <StackPanel x:Name="DriverProgressPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                                    <ProgressBar IsIndeterminate="True" Height="4" Background="#333" Foreground="#4FC3F7" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="TxtDriverProgress" Text="" FontSize="11" Foreground="{StaticResource SubtextBrush}"/>
                                                </StackPanel>

                                                <!-- AMD Warning -->
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#F9E2AF" Margin="0,4,0,0"
                                                           Text="{DynamicResource ui_Drv_AmdNote}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Grid>

                    <!-- ────── About View ────── -->
                    <Grid x:Name="AboutView" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="520" HorizontalAlignment="Center" Margin="0,8,0,24">
                                <!-- App Header with Logo -->
                                <Border Background="{StaticResource MantelBrush}"
                                        BorderBrush="{StaticResource Surface1Brush}" BorderThickness="1"
                                        Padding="16,12" Margin="0,0,0,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="64" Height="64" CornerRadius="0" Margin="0,0,0,8" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <ImageBrush ImageSource="/Assets/logo.png" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{DynamicResource ui_WindowTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource ui_About_Tagline}" FontSize="12" Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <!-- Description -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource ui_About_Description}"
                                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource SubtextBrush}" LineHeight="20" />
                                        <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,14" />
                                        <TextBlock Text="{DynamicResource ui_About_TechStack}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" Margin="0,0,0,6" />
                                        <TextBlock Text="{DynamicResource ui_About_TechLine}" FontSize="11" Foreground="{StaticResource SubtextBrush}" />
                                    </StackPanel>
                                </Border>

                                <!-- Author Credit & Contact -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource ui_About_Credit}"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" />
                                        <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,12" />
                                        <TextBlock Text="{DynamicResource ui_About_Contact}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource OverlayBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                        <TextBlock HorizontalAlignment="Center">
                                            <Hyperlink NavigateUri="https://www.facebook.com/neull" RequestNavigate="Hyperlink_RequestNavigate"
                                                       Foreground="{StaticResource AccentBlueBrush}" TextDecorations="None">
                                                facebook.com/neull
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Update Checker -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <DockPanel>
                                        <Button x:Name="BtnCheckUpdates"
                                                DockPanel.Dock="Right"
                                                Content="{DynamicResource ui_About_CheckUpdates}"
                                                Click="BtnCheckUpdates_Click"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="14,8" FontSize="12"
                                                VerticalAlignment="Center" />
                                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{DynamicResource ui_About_UpdatesTitle}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="{DynamicResource ui_About_CurrentVersion}"
                                                       FontSize="11" Margin="0,3,0,0"
                                                       Foreground="{StaticResource SubtextBrush}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Help Link -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <DockPanel>
                                        <Button x:Name="BtnOpenHelp"
                                                DockPanel.Dock="Right"
                                                Content="{DynamicResource ui_About_HelpLink}"
                                                Click="BtnOpenHelp_Click"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="14,8" FontSize="12"
                                                VerticalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource ui_About_HelpDesc}"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SubtextBrush}" />
                                    </DockPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ────── Donate View ────── -->
                    <Grid x:Name="DonateView" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="520" HorizontalAlignment="Center" Margin="0,8,0,24">
                                <!-- Header -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="☕" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="{DynamicResource ui_Donate_Title}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentPeachBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource ui_Donate_Subtitle}" FontSize="13"
                                                   Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center"
                                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- QR Bank -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource ui_Donate_BankTitle}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <Border Width="240" Height="240" Background="White"
                                                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="1"
                                                HorizontalAlignment="Center" Padding="6">
                                            <Image Source="/Assets/qr_bank.png" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="{DynamicResource ui_Donate_BankNote}" FontSize="11"
                                                   Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center"
                                                   TextAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- PayPal -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{DynamicResource ui_Donate_PaypalTitle}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <Border Background="#11111B" BorderBrush="{StaticResource Surface1Brush}" BorderThickness="1"
                                                Padding="16,12" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📧" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="nhocbobi22@gmail.com" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{DynamicResource ui_Donate_PaypalNote}" FontSize="11"
                                                   Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center"
                                                   TextAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                        <Button Content="{DynamicResource ui_Donate_CopyPaypal}" Click="BtnCopyPaypal_Click"
                                                Style="{StaticResource PrimaryButtonStyle}" Padding="20,10"
                                                HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Thank you -->
                                <Border Style="{StaticResource CardStyle}" Padding="16">
                                    <TextBlock Text="{DynamicResource ui_Donate_Thanks}" FontSize="13"
                                               Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap"
                                               TextAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Border>

            <!-- ────── Active Process Bar ────── -->
            <Border Grid.Row="2" Background="{StaticResource Surface0Brush}" Padding="12,4" BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource DangerButtonStyle}" Click="BtnStopAllMacros_Click" Padding="12,4" FontSize="11"
                            Content="{DynamicResource ui_StopAllMacros}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="ProcessDot" Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,8,0" />
                        <TextBlock x:Name="TxtActiveProcesses" FontSize="12" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ────── Log Console Panel ────── -->
            <Border Grid.Row="3" Background="{StaticResource MantelBrush}" BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="8,4,8,2">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button x:Name="BtnCopyLog"
                                    Content="{DynamicResource ui_Log_CopyBtn}"
                                    Click="BtnCopyLog_Click"
                                    ToolTip="{DynamicResource ui_Log_TooltipCopy}"
                                    Padding="8,2"
                                    Margin="0,0,6,0"
                                    Background="#2a2a3a"
                                    Foreground="#CDD6F4"
                                    BorderBrush="#444466"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    FontSize="10" />
                            <Button DockPanel.Dock="Right" Style="{StaticResource SidebarButtonStyle}" Content="{DynamicResource ui_Log_Clear}" Click="BtnClearLog_Click" FontSize="11" Padding="6,2" />
                        </StackPanel>
                        <TextBlock Text="{DynamicResource ui_LogConsole}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" VerticalAlignment="Center" />
                    </DockPanel>
                    <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="8,0,8,4">
                        <TextBlock x:Name="TxtLogConsole" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ==================== FOOTER ==================== -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{StaticResource MantelBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" FontSize="11"
                           Foreground="{StaticResource OverlayBrush}"
                           VerticalAlignment="Center">
                    <Run Text="{DynamicResource ui_Footer_Runtime}" />
                    <Run Text="{DynamicResource ui_Footer_Sep}" />
                    <Run Text="{DynamicResource ui_Footer_DotNet}" />
                </TextBlock>
                <TextBlock FontSize="11" Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center">
                    <Run Text="{DynamicResource ui_Footer_Credit}" FontWeight="Medium" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Tutorial Overlay (shown on first run) -->
        <local:TutorialOverlay x:Name="TutorialOverlayControl" Grid.ColumnSpan="2" Grid.RowSpan="2"
                               Panel.ZIndex="9999"/>

    </Grid>
</Window>
