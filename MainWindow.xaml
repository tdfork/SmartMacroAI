<!-- Created by Phạm Duy – Giải pháp tự động hóa thông minh. -->
<Window x:Class="SmartMacroAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:SmartMacroAI.Localization"
        xmlns:settings="clr-namespace:SmartMacroAI.Localization"
        xmlns:local="clr-namespace:SmartMacroAI"
        mc:Ignorable="d"
        Title="{DynamicResource ui_WindowTitle}"
        Icon="pack://application:,,,/Assets/logo.ico"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BaseBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- ── System-color overrides: force dark popup / highlight for ALL ComboBoxes & Menus ── -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E1E2E" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#CDD6F4" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#45475A" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#585B70" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#CDD6F4" />
        <!-- Menu popup background -->
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#1E1E2E" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#CDD6F4" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#45475A" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#1E1E2E" />

        <!-- ── Dark ComboBoxItem ControlTemplate ── -->
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#CDD6F4" />
            <Setter Property="Background" Value="#1E1E2E" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#585B70" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ComboBox ToggleButton (arrow area) ── -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Bd" Grid.ColumnSpan="2" CornerRadius="0"
                        Background="#1A1A2E" BorderBrush="#45475A" BorderThickness="1"
                        SnapsToDevicePixels="True" />
                <Border Grid.Column="0" CornerRadius="0" Margin="1"
                        Background="Transparent" />
                <Path x:Name="Arrow" Grid.Column="1"
                      Fill="#A6ADC8" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#585B70" />
                    <Setter TargetName="Arrow" Property="Fill" Value="#CDD6F4" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA" />
                    <Setter TargetName="Arrow" Property="Fill" Value="#89B4FA" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ── Full dark-themed ComboBox Style ── -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#CDD6F4" />
            <Setter Property="Background" Value="#1A1A2E" />
            <Setter Property="BorderBrush" Value="#45475A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggleButton}"
                                          Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}" />
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,3,28,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CDD6F4" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     Margin="4,3,28,3"
                                     Focusable="True"
                                     Background="Transparent"
                                     Foreground="#CDD6F4"
                                     CaretBrush="#CDD6F4"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1E1E2E"
                                            BorderBrush="#45475A"
                                            BorderThickness="1"
                                            CornerRadius="0"
                                            Margin="0,1,0,0">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6C7086" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Geometry x:Key="DashboardIcon">M4 13h6a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1zm-1 7h6a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1zm10 0h6a1 1 0 0 0 1-1v-8a1 1 0 0 0-1-1h-6a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1zM13 4v4a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1h-6a1 1 0 0 0-1 1z</Geometry>
        <Geometry x:Key="MacroIcon">M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM9 13l2 2-2 2M15 13l-2 2 2 2</Geometry>
        <Geometry x:Key="ImageIcon">M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM8.5 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM21 15l-5-5L5 21</Geometry>
        <Geometry x:Key="OcrIcon">M17 8h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2M7 8H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2M7 12h10</Geometry>
        <Geometry x:Key="SettingsIcon">M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z</Geometry>
        <Geometry x:Key="AboutIcon">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z</Geometry>
        <Geometry x:Key="StealthIcon">M13.875 18.825A10.05 10.05 0 0 1 12 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 0 1 4.02-5.272M6.61 6.61A9.97 9.97 0 0 1 12 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 0 1-4.132 5.411m-5.154-.776a3 3 0 0 1-4.243-4.243M2 2l20 20</Geometry>
        <Geometry x:Key="PlayIcon">M5 3l14 9-14 9V3z</Geometry>
        <Geometry x:Key="StopIcon">M6 4h4v16H6zM14 4h4v16h-4z</Geometry>

        <loc:ResourceKeyConcatConverter x:Key="StatusLocConverter" Prefix="ui_Status_" />
        <loc:ResourceKeyConcatConverter x:Key="StealthStatusLocConverter" Prefix="ui_StealthStatus_" />
        <loc:ResourceKeyConcatConverter x:Key="StealthToggleLocConverter" Prefix="ui_StealthToggle_" />
        <loc:ActionCountFormatConverter x:Key="ActionCountFmtConverter" />

        <!-- ── Telegram ToggleButton Style — color driven entirely by XAML DataTriggers ── -->
        <Style x:Key="TelegramToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Telegram: TẮT"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="Orange"/>
                    <Setter Property="ToolTip" Value="{DynamicResource ui_Telegram_On}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Foreground" Value="Gray"/>
                    <Setter Property="ToolTip" Value="{DynamicResource ui_Telegram_Off}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Bool → Telegram tooltip converter ── -->
        <local:BoolToTelegramTooltipConverter x:Key="BoolToTelegramTooltipConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{StaticResource MantelBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="14,14,14,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="0" Margin="0,0,10,0">
                                <Border.Background>
                                    <ImageBrush ImageSource="/Assets/logo.png" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource ui_WindowTitle}" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{x:Static local:MainWindow.AppVersion}" FontSize="10"
                                           Foreground="{StaticResource OverlayBrush}" Margin="0,-1,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Top" Height="1" Margin="16,0" Background="{StaticResource Surface0Brush}" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                    <Border Height="1" Margin="16,8" Background="{StaticResource Surface0Brush}" />
                    <Button x:Name="BtnAbout" Style="{StaticResource SidebarButtonStyle}" Click="BtnAbout_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource AboutIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                            <TextBlock Text="{DynamicResource ui_About}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnDonate" Style="{StaticResource SidebarButtonStyle}" Click="BtnDonate_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☕" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource ui_Donate}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSettingsNav" Style="{StaticResource SidebarButtonStyle}" Click="BtnSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource SettingsIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" Fill="Transparent" />
                            <TextBlock Text="{DynamicResource ui_Settings}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ui_Navigation}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" Margin="24,8,0,8" />
                        <Button x:Name="BtnDashboard" Style="{StaticResource SidebarButtonActiveStyle}" Click="BtnDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource DashboardIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="{DynamicResource ui_Dashboard}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnMacroEditor" Style="{StaticResource SidebarButtonStyle}" Click="BtnMacroEditor_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource MacroIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="{DynamicResource ui_MacroEditor}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnImageRecognition" Style="{StaticResource SidebarButtonStyle}" Click="BtnImageRecognition_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource ImageIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="{DynamicResource ui_ImageRecognition}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnOcrEngine" Style="{StaticResource SidebarButtonStyle}" Click="BtnOcrEngine_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource OcrIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="{DynamicResource ui_OcrEngine}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnStealthManager" Style="{StaticResource SidebarButtonStyle}" Click="BtnStealthManager_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource StealthIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="{DynamicResource ui_StealthManager}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnProfileManager" Style="{StaticResource SidebarButtonStyle}" Click="BtnProfileManager_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="{DynamicResource ui_Dash_ProfileName}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ==================== MAIN CONTENT AREA ==================== -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="160" />
            </Grid.RowDefinitions>

            <!-- Top Header Bar -->
            <Border Grid.Row="0" Background="{StaticResource BaseBrush}" Padding="16,10" BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- File Menu -->
                    <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,16,0">
                        <MenuItem Header="{DynamicResource ui_Menu_File}" Foreground="{StaticResource TextBrush}" FontSize="12" BorderThickness="0" Background="Transparent">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="Background" Value="#1E1E2E"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#45475A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.ItemContainerStyle>
                            <MenuItem Header="{DynamicResource ui_Menu_NewMacro}" Click="BtnNewMacro_Click" />
                            <MenuItem Header="{DynamicResource ui_Menu_OpenMacro}" Click="BtnLoadMacro_Click" />
                            <MenuItem Header="{DynamicResource ui_Menu_SaveMacro}" Click="BtnSaveMacro_Click" />
                            <Separator />
                            <MenuItem Header="{DynamicResource ui_Menu_Share}" Click="BtnShareScript_Click" />
                            <MenuItem Header="{DynamicResource ui_Menu_Import}" Click="BtnImportScript_Click" />
                        </MenuItem>
                    </Menu>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Notification Bell -->
                        <Button x:Name="BtnNotifications"
                                Click="BtnNotifications_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8,4"
                                ToolTip="{DynamicResource ui_Notification_Btn}"
                                Margin="0,0,8,0"
                                Width="36" Height="32">
                            <Grid>
                                <TextBlock Text="🔔" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- Unread badge -->
                                <Border x:Name="NotificationBadge"
                                        Background="#F38BA8"
                                        CornerRadius="8"
                                        MinWidth="16" Height="16"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,-4,-4,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="TxtBadgeCount"
                                               Foreground="White" FontSize="9"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Notification Popup -->
                        <Popup x:Name="NotificationPopup"
                               PlacementTarget="{Binding ElementName=BtnNotifications}"
                               Placement="Bottom" StaysOpen="False"
                               Width="340">
                            <Border Background="#1E1E2E"
                                    BorderBrush="#313244" BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*" MaxHeight="400"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0" Background="#181825" Margin="0,0,0,1" CornerRadius="8,8,0,0">
                                        <Grid Margin="12,8">
                                            <TextBlock Text="{DynamicResource ui_Notification_Header}"
                                                       Foreground="#CDD6F4" FontSize="13"
                                                       FontWeight="Bold"/>
                                            <Button Content="{DynamicResource ui_Notification_MarkAll}"
                                                    Click="BtnMarkAllRead_Click"
                                                    HorizontalAlignment="Right"
                                                    FontSize="11"
                                                    Background="Transparent"
                                                    Foreground="#89B4FA"
                                                    BorderThickness="0"
                                                    Cursor="Hand"/>
                                        </Grid>
                                    </Border>

                                    <!-- Notification list -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  MaxHeight="350">
                                        <ItemsControl x:Name="NotificationList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="12,8"
                                                            BorderBrush="#313244"
                                                            BorderThickness="0,0,0,1"
                                                            Background="#1E1E2E">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding TypeIcon}"
                                                                       FontSize="14"
                                                                       VerticalAlignment="Top"
                                                                       Margin="0,0,0,0"/>
                                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="#CDD6F4"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Message}"
                                                                           Foreground="#A6ADC8"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding TimeAgo}"
                                                                       Foreground="#6C7086"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Top"
                                                                       Margin="8,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Footer -->
                                    <Border Grid.Row="2" Background="#181825" Padding="8" CornerRadius="0,0,8,8">
                                        <Button Content="{DynamicResource ui_Notification_ClearAll}"
                                                Click="BtnClearNotifications_Click"
                                                HorizontalAlignment="Center"
                                                FontSize="11"
                                                Background="Transparent"
                                                Foreground="#F38BA8"
                                                BorderThickness="0"
                                                Cursor="Hand"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Popup>

                        <Border Background="{StaticResource Surface0Brush}" CornerRadius="0" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush x:Name="StatusIndicator" Color="{StaticResource AccentGreenColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="TxtStatus" Text="{DynamicResource ui_Header_Ready}" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnRecordMacro" Style="{StaticResource DangerButtonStyle}" Click="BtnRecordMacro_Click" Margin="0,0,8,0" Padding="12,6">
                            <TextBlock><Run Text="&#x23FA;" /><Run Text="{DynamicResource ui_RecordSuffix}" /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_NewMacro}" Click="BtnNewMacro_Click" />
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtPageTitle" Text="{DynamicResource ui_Page_Dashboard}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                        <TextBlock x:Name="TxtPageSubtitle" Text="{DynamicResource ui_PageSub_Dashboard}" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Frame -->
            <Border Grid.Row="1" Padding="12,8,12,6">
                <Grid x:Name="ContentArea">

                    <!-- ────── Dashboard View (Trạm điều hành đa nhiệm) ────── -->
                    <Grid x:Name="DashboardView">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Stats Row -->
                        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,8">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ui_SavedMacros}" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                                    <TextBlock x:Name="TxtTotalMacros" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ui_RunsToday}" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                                    <TextBlock x:Name="TxtRunsToday" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ui_ActiveThreads}" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                                    <TextBlock x:Name="TxtActiveThreads" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentPeachBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Scheduled Macros Info Bar -->
                        <Border Grid.Row="0" Background="#1A2A1A" BorderBrush="#A6E3A1" BorderThickness="0,0,0,1"
                                Margin="0,0,0,8" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏰ " Foreground="#A6E3A1" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtScheduledCount" Foreground="#A6E3A1" FontSize="13"
                                           Text="{DynamicResource ui_Dash_ScheduledFmt}" VerticalAlignment="Center"/>
                                <TextBlock Text="  |  " Foreground="#6C7086" FontSize="13" VerticalAlignment="Center" Margin="8,0"/>
                                <TextBlock x:Name="TxtRunningCount" Foreground="#CDD6F4" FontSize="13"
                                           Text="{DynamicResource ui_Dash_RunningFmt}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid Multi-tasking Hub -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0" Padding="0">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="8,8,8,6">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="▶▶ Run Selected" Click="BtnRunAllParallel_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" Background="#A6E3A1" Foreground="#1E1E2E" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" ToolTip="Chạy các macro đã tick (song song)" />
                                        <Button Style="{StaticResource DangerButtonStyle}" Content="{DynamicResource ui_StopAll}" Click="BtnStopAllMacros_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" />
                                        <Button Click="BtnGlobalHistory_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" Background="#45475A" Foreground="#CDD6F4" BorderThickness="0" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📊" Margin="0,0,4,0"/>
                                                <TextBlock Text="{DynamicResource ui_Dash_History}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Refresh}" Click="BtnRefreshDashboard_Click" Padding="12,6" FontSize="11" />
                                    </StackPanel>
                                    <TextBlock Text="{DynamicResource ui_Dashboard_HubTitle}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                </DockPanel>
                                <Grid>
                                    <TextBlock x:Name="DashboardEmptyHint"
                                               Text="{DynamicResource ui_Dashboard_EmptyHint}"
                                               FontSize="13" Foreground="{StaticResource OverlayBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="0,40,0,0" Visibility="Collapsed" />
                                    <DataGrid x:Name="DashboardGrid"
                                              MinHeight="150"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              CanUserReorderColumns="False" CanUserSortColumns="False"
                                              CanUserResizeColumns="True"
                                              IsReadOnly="False"
                                              SelectionMode="Single" SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="{StaticResource Surface1Brush}"
                                              Background="{StaticResource BaseBrush}"
                                              RowBackground="#181825"
                                              AlternatingRowBackground="#1E1E2E"
                                              BorderThickness="0"
                                              ColumnHeaderHeight="32"
                                              RowHeight="58"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">

                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="{StaticResource MantelBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="FontSize" Value="11" />
                                                <Setter Property="Padding" Value="8,6" />
                                                <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
                                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A2A3D" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#2A2A3D" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Focusable" Value="False" />
                                                <Setter Property="IsHitTestVisible" Value="True" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="DataGridCell">
                                                            <ContentPresenter VerticalAlignment="Center" Margin="4,0" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </DataGrid.CellStyle>

                                        <DataGrid.Columns>

                                            <!-- Col 0: Checkbox for parallel selection -->
                                            <DataGridTemplateColumn Width="36" MinWidth="36">
                                                <DataGridTemplateColumn.HeaderTemplate>
                                                    <DataTemplate>
                                                        <CheckBox x:Name="ChkSelectAll" Click="ChkSelectAllDashboard_Click"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  ToolTip="Chọn tất cả"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.HeaderTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Col 1: Tên macro — flexible, always visible -->
                                            <DataGridTemplateColumn Header="{DynamicResource ui_Dash_Col_Name}" Width="*" MinWidth="140">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="4,0">
                                                            <!-- Display mode -->
                                                            <StackPanel Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="{Binding MacroName}"
                                                                           Foreground="#CDD6F4" FontSize="13" FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{DynamicResource ui_Dash_TooltipRename}"
                                                                           MouseLeftButtonDown="MacroName_DoubleClick"/>
                                                                <TextBlock Foreground="#6C7086" FontSize="10">
                                                                    <Run Text="{Binding ActionCount, Mode=OneWay}"/>
                                                                    <Run Text="{DynamicResource ui_Dash_Actions}"/>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <!-- Edit mode -->
                                                            <TextBox x:Name="TxtRename"
                                                                     Text="{Binding MacroName, UpdateSourceTrigger=PropertyChanged}"
                                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                                     Background="#313244" Foreground="#CDD6F4"
                                                                     BorderBrush="#89B4FA" BorderThickness="1"
                                                                     Padding="6,4" FontSize="13"
                                                                     Margin="0"
                                                                     LostFocus="TxtRename_LostFocus"
                                                                     KeyDown="TxtRename_KeyDown"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Col 2: Cửa sổ mục tiêu — fixed width -->
                                            <DataGridTemplateColumn Header="{DynamicResource ui_Dash_Col_Target}" Width="180" MinWidth="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <Button DockPanel.Dock="Right" Content="🎯" Click="DashboardIdentify_Click"
                                                                    ToolTip="{DynamicResource ui_Tooltip_FlashWindow}"
                                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                                    Background="#45475A" Foreground="#CDD6F4"
                                                                    FontSize="11" Padding="4,2" Margin="2,0,0,0" />
                                                            <ComboBox Text="{Binding TargetWindow, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                      IsEditable="True" FontSize="10"
                                                                      Style="{StaticResource DarkComboBoxStyle}"
                                                                      Margin="2,0"
                                                                      DropDownOpened="DashRowWindowCombo_DropDownOpened"
                                                                      SelectionChanged="DashRowWindowCombo_SelectionChanged" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Col 3: Chế độ — Stealth + HW icon toggles -->
                                            <DataGridTemplateColumn Header="{DynamicResource ui_Dash_Col_Mode}" Width="70" MinWidth="70">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <ToggleButton Content="👁" Width="30" Height="26"
                                                                          IsChecked="{Binding StealthMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ToolTip="{DynamicResource ui_Dash_TooltipStealth}"
                                                                          Margin="1,0" FontSize="11"/>
                                                            <ToggleButton Content="⚡" Width="30" Height="26"
                                                                          IsChecked="{Binding HardwareMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ToolTip="{DynamicResource ui_Dash_TooltipHW}"
                                                                          Margin="1,0" FontSize="11"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Col 4: Lặp / Giãn cách — compact inputs -->
                                            <DataGridTemplateColumn Header="{DynamicResource ui_Dash_Col_Repeat}" Width="110" MinWidth="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <TextBox Text="{Binding RunCount, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                     Width="40" FontSize="12" TextAlignment="Center"
                                                                     Background="#313244" Foreground="#CDD6F4"
                                                                     BorderBrush="#45475A" BorderThickness="1"
                                                                     Padding="2,1" Margin="1,0"
                                                                     ToolTip="{DynamicResource ui_Dash_TooltipRepeat}"/>
                                                            <TextBlock Text="/" Foreground="#6C7086"
                                                                       VerticalAlignment="Center" Margin="2,0"/>
                                                            <TextBox Text="{Binding IntervalMinutes, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                     Width="40" FontSize="12" TextAlignment="Center"
                                                                     Background="#313244" Foreground="#CDD6F4"
                                                                     BorderBrush="#45475A" BorderThickness="1"
                                                                     Padding="2,1" Margin="1,0"
                                                                     ToolTip="{DynamicResource ui_Dash_TooltipInterval}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Col 5: Trạng thái + Lịch — combined -->
                                            <DataGridTemplateColumn Header="{DynamicResource ui_Dash_Col_Status}" Width="130" MinWidth="110">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="2,0">
                                                            <!-- Status badge -->
                                                            <Border CornerRadius="3" Padding="5,2" HorizontalAlignment="Left">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#A6E3A1"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                                <Setter Property="Background" Value="#F9E2AF"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Waiting">
                                                                                <Setter Property="Background" Value="#89B4FA"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Stopped">
                                                                                <Setter Property="Background" Value="#F38BA8"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                                <Setter Property="Background" Value="#F38BA8"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Status}" Foreground="#1E1E2E" FontSize="11" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <!-- Schedule summary -->
                                                            <TextBlock Text="{Binding ScheduleSummary}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#6C7086"/>
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasSchedule}" Value="True">
                                                                                <Setter Property="Foreground" Value="#FAB387"/>
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Col 6: Điều khiển — fixed-width column to prevent overflow -->
                                            <DataGridTemplateColumn Header="{DynamicResource ui_Dash_Col_Controls}" Width="210" MinWidth="210">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="2,4" Width="204">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Row 1: Primary actions — 3 equal buttons -->
                                                            <Grid Grid.Row="0" Margin="0,0,0,3">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Button Grid.Column="0" Margin="0,0,2,0" Height="26"
                                                                        Background="#A6E3A1" Foreground="#1E1E2E"
                                                                        FontWeight="Bold" FontSize="11"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        Click="DashboardStart_Click"
                                                                        IsEnabled="{Binding CanStart}"
                                                                        ToolTip="{DynamicResource ui_Dash_TooltipRun}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Path Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="#1E1E2E" Width="10" Height="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                        <TextBlock Text="{DynamicResource ui_Dash_RunBtn}"/>
                                                                    </StackPanel>
                                                                </Button>

                                                                <Button Grid.Column="1" Margin="0,0,2,0" Height="26"
                                                                        Background="#F38BA8" Foreground="#1E1E2E"
                                                                        FontWeight="Bold" FontSize="11"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        Click="DashboardStop_Click"
                                                                        IsEnabled="{Binding CanStop}"
                                                                        ToolTip="{DynamicResource ui_Dash_TooltipStop}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Path Data="M6,6H18V18H6V6Z" Fill="#1E1E2E" Width="10" Height="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                        <TextBlock Text="{DynamicResource ui_Dash_StopBtn}"/>
                                                                    </StackPanel>
                                                                </Button>

                                                                <Button Grid.Column="2" Height="26"
                                                                        Background="#89B4FA" Foreground="#1E1E2E"
                                                                        FontWeight="Bold" FontSize="11"
                                                                        BorderThickness="0" Cursor="Hand"
                                                                        Click="DashboardRename_Click"
                                                                        ToolTip="{DynamicResource ui_Dash_TooltipEdit}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="#1E1E2E" Width="10" Height="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                        <TextBlock Text="{DynamicResource ui_Dash_EditBtn}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                            </Grid>

                                                            <!-- Row 2: Secondary actions — 5 equal buttons -->
                                                            <Grid Grid.Row="1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Schedule -->
                                                                <Button Grid.Column="0" Margin="0,0,2,0" Height="22"
                                                                        Background="#313244" Foreground="#FAB387"
                                                                        FontSize="11" BorderThickness="0" Cursor="Hand"
                                                                        Click="BtnDashSchedule_Click"
                                                                        ToolTip="{Binding ScheduleSummary}">
                                                                    <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M16.2,16.2L11,13V7H12.5V12.2L17,14.9L16.2,16.2Z" Fill="#FAB387" Width="10" Height="10" Stretch="Uniform"/>
                                                                </Button>

                                                                <!-- History -->
                                                                <Button Grid.Column="1" Margin="0,0,2,0" Height="22"
                                                                        Background="#313244" Foreground="#89DCEB"
                                                                        FontSize="11" BorderThickness="0" Cursor="Hand"
                                                                        Click="BtnDashHistory_Click"
                                                                        ToolTip="{DynamicResource ui_Dash_TooltipHistory}">
                                                                    <Path Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3Z" Fill="#89DCEB" Width="10" Height="10" Stretch="Uniform"/>
                                                                </Button>

                                                                <!-- Lock -->
                                                                <Button Grid.Column="2" Margin="0,0,2,0" Height="22"
                                                                        Background="#313244" Foreground="#CBA6F7"
                                                                        FontSize="11" BorderThickness="0" Cursor="Hand"
                                                                        Click="BtnDashLock_Click"
                                                                        ToolTip="{Binding LockStatus}">
                                                                    <Path Width="10" Height="10" Stretch="Uniform">
                                                                        <Path.Style>
                                                                            <Style TargetType="Path">
                                                                                <Setter Property="Data" Value="M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6C4.89,22 4,21.1 4,20V10A2,2 0 0,1 6,8H15V6A3,3 0 0,0 12,3A3,3 0 0,0 9,6H7A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,17A2,2 0 0,0 14,15A2,2 0 0,0 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17Z"/>
                                                                                <Setter Property="Fill" Value="#CBA6F7"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                                        <Setter Property="Data" Value="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Path.Style>
                                                                    </Path>
                                                                </Button>

                                                                <!-- Telegram -->
                                                                <ToggleButton Grid.Column="3" Margin="0,0,2,0" Height="22"
                                                                             IsChecked="{Binding SendTelegramOnComplete, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             ToolTip="{DynamicResource ui_Dash_TooltipTelegram}"
                                                                             Background="#313244" Foreground="#A6E3A1"
                                                                             BorderThickness="0" Cursor="Hand">
                                                                    <Path Data="M10,21H14A2,2 0 0,1 12,23A2,2 0 0,1 10,21M21,19V20H3V19L5,17V11C5,7.9 7.03,5.17 10,4.29C10,4.19 10,4.1 10,4A2,2 0 0,1 12,2A2,2 0 0,1 14,4C14,4.1 14,4.19 14,4.29C16.97,5.17 19,7.9 19,11V17L21,19Z" Fill="#A6E3A1" Width="11" Height="11" Stretch="Uniform"/>
                                                                </ToggleButton>

                                                                <!-- Delete -->
                                                                <Button Grid.Column="4" Height="22"
                                                                        Background="#313244" Foreground="#F38BA8"
                                                                        FontSize="12" BorderThickness="0" Cursor="Hand"
                                                                        Click="DashboardDelete_Click"
                                                                        ToolTip="{DynamicResource ui_Dash_TooltipDelete}">
                                                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#F38BA8" Width="10" Height="10" Stretch="Uniform"/>
                                                                </Button>
                                                            </Grid>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </DockPanel>
