                                            Background="#1a2a1a" BorderBrush="#4a8a4a"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="8,5" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🎮" Margin="0,0,6,0" FontSize="14"/>
                                            <StackPanel>
                                                <TextBlock x:Name="TxtGameDetected"
                                                           Text="{DynamicResource ui_GameDetected}"
                                                           FontWeight="SemiBold" FontSize="12" Foreground="#6daa45"/>
                                                <TextBlock x:Name="TxtGameDetectedSub"
                                                           Text="" FontSize="11" Foreground="#888"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Margin="0,0,14,0">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_Repeat}" />
                                            <TextBox x:Name="TxtRepeatCount" Style="{StaticResource DarkTextBoxStyle}" Width="56" Text="1" ToolTip="{DynamicResource ui_Tooltip_Repeat}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource ui_Lbl_AutoStopMinutes}" />
                                            <TextBox x:Name="TxtAutoStopMinutes" Style="{StaticResource DarkTextBoxStyle}" Width="56" Text="0" ToolTip="{DynamicResource ui_Tooltip_AutoStopMinutes}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" Margin="0,0,12,0">
                                    <CheckBox x:Name="ChkHardwareMode"
                                              Foreground="{StaticResource TextBrush}" FontSize="11"
                                              VerticalAlignment="Center"
                                              ToolTip="{DynamicResource ui_Tooltip_HWCheckbox}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚡" FontSize="13" Margin="0,0,4,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{DynamicResource ui_HwMode}" FontSize="11" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </CheckBox>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Save}" Click="BtnSaveMacro_Click" Margin="0,0,6,0" Padding="16,8" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="{DynamicResource ui_Load}" Click="BtnLoadMacro_Click" Margin="0,0,6,0" Padding="16,8" />
                                    <Button Style="{StaticResource SidebarButtonStyle}" Content="📤" ToolTip="{DynamicResource ui_Tooltip_Share}" Click="BtnShareScript_Click" Padding="10,8" FontSize="14" Margin="0,0,4,0" />
                                    <Button Style="{StaticResource SidebarButtonStyle}" Content="📥" ToolTip="{DynamicResource ui_Tooltip_Import}" Click="BtnImportScript_Click" Padding="10,8" FontSize="14" Margin="0,0,6,0" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="{DynamicResource ui_Clear}" Click="BtnClearCanvas_Click" Margin="0,0,6,0" Padding="16,8" />
                                    <Border Width="1" Background="{StaticResource Surface1Brush}" Margin="4,2,10,2" />
                                    <Button x:Name="BtnRunMacro" Click="BtnRunMacro_Click"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Background="#A6E3A1" Foreground="#1E1E2E"
                                            Padding="16,8" FontSize="12"
                                            Content="{DynamicResource ui_Run}" />
                                    <Button x:Name="BtnStopMacro" Click="BtnStopMacro_Click" IsEnabled="False" Margin="6,0,0,0"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Padding="16,8" FontSize="12"
                                            Content="{DynamicResource ui_Stop}" />
                                            <Button x:Name="BtnShowLog" Click="BtnShowLog_Click"
                                                    ToolTip="{DynamicResource ui_Tooltip_ViewLog}"
