<!-- Tutorial Overlay — First-run wizard with spotlight highlighting -->
<UserControl x:Class="SmartMacroAI.TutorialOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">

    <Grid x:Name="OverlayGrid">
        <!-- Semi-transparent backdrop -->
        <Border x:Name="Backdrop" Background="#CC000000" Opacity="0.7"/>

        <!-- Tutorial card (centered) -->
        <Border x:Name="TutorialCard"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1E1E2E"
                BorderBrush="#89B4FA"
                BorderThickness="2"
                CornerRadius="12"
                Padding="32,24"
                MaxWidth="480"
                MinWidth="360">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <!-- Step indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <ItemsControl x:Name="StepDots">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>

                <!-- Title -->
                <TextBlock x:Name="TxtTitle"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#CDD6F4"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                <!-- Description -->
                <TextBlock x:Name="TxtDescription"
                           FontSize="14"
                           Foreground="#A6ADC8"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Skip button -->
                    <Button x:Name="BtnSkip" Grid.Column="0"
                            Content="Bỏ qua"
                            Click="BtnSkip_Click"
                            HorizontalAlignment="Left"
                            Padding="16,8"
                            Background="Transparent"
                            Foreground="#6C7086"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"/>

                    <!-- Back button -->
                    <Button x:Name="BtnBack" Grid.Column="1"
                            Content="← Quay lại"
                            Click="BtnBack_Click"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            Background="#45475A"
                            Foreground="#CDD6F4"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            Visibility="Collapsed"/>

                    <!-- Next button -->
                    <Button x:Name="BtnNext" Grid.Column="2"
                            Content="Tiếp theo →"
                            Click="BtnNext_Click"
                            Padding="20,10"
                            Background="#89B4FA"
                            Foreground="#1E1E2E"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="13"
                            FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
