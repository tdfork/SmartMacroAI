    <!-- Data CSV Tab -->
    <system:String x:Key="ui_Settings_DataCSV_Title">Data-Driven CSV Execution</system:String>
    <system:String x:Key="ui_Settings_DataCSV_Subtitle">Load a CSV or pipe-separated TXT file to run your macro once per row. Column headers become {{variable}} names (spaces stripped, case-insensitive).</system:String>
    <system:String x:Key="ui_Settings_DataCSV_LoadButton">📂 Load CSV/TXT</system:String>
    <system:String x:Key="ui_Settings_DataCSV_ClearButton">🗑 Clear</system:String>
    <system:String x:Key="ui_Settings_DataCSV_SkipOnError">Skip to next row if an error occurs (continue running)</system:String>
    <system:String x:Key="ui_Settings_DataCSV_SkipDesc">When unchecked, the macro stops on the first error. When checked, failed rows are logged and skipped.</system:String>
    <system:String x:Key="ui_Settings_DataCSV_HowToUse">How to use:</system:String>
    <system:String x:Key="ui_Settings_DataCSV_Step1">1. Create a CSV/TXT file with headers in row 1 (e.g. username, password, email)</system:String>
    <system:String x:Key="ui_Settings_DataCSV_Step2">2. Load the file above — each column header becomes a variable: {{username}}</system:String>
    <system:String x:Key="ui_Settings_DataCSV_Step3">3. In your macro, use {{username}}, {{password}} in TypeText, Navigate, or Telegram actions</system:String>
    <system:String x:Key="ui_Settings_DataCSV_Step4">4. Run the macro — it will execute once per row with those variables substituted</system:String>
    <system:String x:Key="ui_Settings_DataCSV_Step5">5. After each row, check logs/run_*.txt for the execution log</system:String>

